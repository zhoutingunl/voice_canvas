# 复制为 .env 并填入真实值；.env 已被 .gitignore 忽略，绝不提交到仓库。
# 键名必须与 backend/config.py 一致。

# ===== MiniMax（指令解析 MiniMax-M3 + 实体生图 image-01-live）=====
MINIMAX_API_KEY=                                  # MiniMax 平台申请
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic   # Anthropic 兼容端点，勿删 /anthropic
MINIMAX_LLM_MODEL=MiniMax-M3
MINIMAX_IMAGE_MODEL=image-01-live

# ===== 阿里百炼 DashScope（云端 ASR / 手机端 & 付费用户路径）=====
BAILIAN_API_KEY=                                  # 阿里云百炼 DashScope 申请，sk- 开头
BAILIAN_ASR_MODEL=paraformer-realtime-v2

# ===== 后端服务 =====
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
ALLOWED_ORIGINS=http://localhost:5173
